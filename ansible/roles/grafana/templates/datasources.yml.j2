apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: {{ grafana_prometheus_url }}
    isDefault: true
    editable: true
    jsonData:
      timeInterval: "15s"
      httpMethod: POST

  - name: Jaeger
    type: jaeger
    access: proxy
    url: {{ grafana_jaeger_url }}
    editable: true
    jsonData:
      tracesToLogs:
        datasourceUid: prometheus
        tags: ["service"]
        mappedTags:
          - key: "service.name"
            value: "service"
        filterByTraceID: true
        filterBySpanID: true
