      "title": "Backend — Requests by Method and Route",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"voting-backend\"}[5m])) by (method, route)",
          "legendFormat": "{{ method }} {{ route }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
