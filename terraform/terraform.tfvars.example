###############################################################################
# terraform.tfvars.example — Copy to terraform.tfvars and fill in values
###############################################################################

aws_region                  = "eu-west-1"
app_instance_type           = "t3.medium"
observability_instance_type = "t3.medium"
allowed_ssh_cidr            = "0.0.0.0/0"     # Restrict to your IP in production
grafana_password            = "changeme123"    # Change this

# AMI: defaults to Ubuntu 22.04 LTS eu-west-1 in variables.tf.
# If the default doesn't work in your account, find yours at:
#   https://cloud-images.ubuntu.com/locator/ec2/
# Then uncomment and set:
# ami_id = "ami-xxxxxxxxxxxxxxxxx"

# project_name = "advance-monitoring"   # (default)
# vpc_cidr     = "10.0.0.0/16"          # (default)

# SSH key pair is auto-generated by Terraform. After apply, extract it:
#   terraform output -raw ssh_private_key > ~/.ssh/deploy_key.pem
#   chmod 600 ~/.ssh/deploy_key.pem

# project_name = "advance-monitoring"   # (default)
# vpc_cidr     = "10.0.0.0/16"          # (default)

# SSH key pair is auto-generated from project_name.
# After `terraform apply`, run:
#   terraform output -raw ssh_private_key > ~/.ssh/deploy_key.pem
#   chmod 600 ~/.ssh/deploy_key.pem
