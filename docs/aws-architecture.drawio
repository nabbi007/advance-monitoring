                <!-- ═══════════════════════════════════════════════════════════ -->
                <mxCell id="crosssg" value="&lt;b style=&quot;font-size:10px;color:#DD3522&quot;&gt;Cross-SG Rules&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#DD3522&quot;&gt;App → Obs : OTLP 4317, 4318&lt;br&gt;Obs → App : Scrape 3000, 3001, 9100, 9121&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF2F8;strokeColor=#DD3522;fontSize=9;verticalAlign=middle;dashed=1;dashPattern=6 4;" parent="1" vertex="1">
